# OpenRouter API Key (Required - at least one provider needed)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenRouter API endpoint (no need to change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq API Key (Optional - completely free)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# OpenCode Zen API Key (Optional - partially free models)
# Get your key at: https://opencode.ai/auth
OPENCODE_API_KEY=sk-your-key-here

# Longcat API Key (Optional - OpenAI compatible)
# Get your key at: https://longcat.chat/platform/api-keys
LONGCAT_API_KEY=lc-your-key-here

# Server port (default: 8765)
PORT=8765
